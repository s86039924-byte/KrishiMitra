# --- Google GenAI / Gemma ---
# Get a key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# Model IDs (defaults match the Kaggle notebook)
GEMMA_MODEL=models/gemma-4-31b-it
GEMMA_FALLBACK_MODEL=models/gemma-4-26b-a4b-it
GEMMA_MAX_RETRIES=2

# --- CORS ---
# Comma-separated origins allowed to call the API. "*" for local dev.
CORS_ORIGINS=*

# --- Optional: Unicode font for Hindi/Bengali PDF rendering ---
# Absolute path to a TTF (e.g. NotoSansDevanagari-Regular.ttf).
# KRISHIMITRA_PDF_FONT=/path/to/NotoSansDevanagari-Regular.ttf
